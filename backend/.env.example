# ── EventPro backend configuration ──────────────────────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.

# Database. Leave blank to use a local SQLite file (./eventpro.db) for dev.
# For production use MySQL/TiDB, e.g.:
# DATABASE_URL=mysql+pymysql://user:password@host:4000/dbname
DATABASE_URL=

# JWT signing secret. REQUIRED in production. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Comma-separated list of allowed CORS origins (frontend URLs).
# Example: https://your-frontend.com,https://www.your-frontend.com
ALLOWED_ORIGINS=

# Cerebras AI API key (optional — rule-based fallback is used if empty).
CEREBRAS_API_KEY=

# Server config
HOST=0.0.0.0
PORT=8000
